{
  "name": "onlyiflow",
  "version": "0.4.0",
  "description": "Explicit project-local development-flow state and deterministic landing evidence.",
  "author": {
    "name": "OnlyiFlow"
  },
  "license": "UNLICENSED",
  "skills": "skills-claude",
  "mcpServers": {
    "onlyiflow": {
      "command": "python",
      "args": [
        "-B",
        "${ZCODE_PLUGIN_ROOT}/server/stdio.py"
      ],
      "cwd": "${ZCODE_PROJECT_DIR}",
      "env": {
        "FASTMCP_CHECK_FOR_UPDATES": "off",
        "FASTMCP_SHOW_SERVER_BANNER": "false",
        "PYTHONUNBUFFERED": "1"
      }
    }
  }
}
