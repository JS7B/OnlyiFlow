{
  "mcpServers": {
    "onlyiflow": {
      "command": "python",
      "args": [
        "-B",
        "${CLAUDE_PLUGIN_ROOT}/server/stdio.py"
      ],
      "cwd": "${CLAUDE_PLUGIN_ROOT}",
      "env": {
        "FASTMCP_CHECK_FOR_UPDATES": "off",
        "FASTMCP_SHOW_SERVER_BANNER": "false",
        "PYTHONUNBUFFERED": "1"
      }
    }
  }
}
